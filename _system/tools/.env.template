# 워크스페이스 도구 환경변수 템플릿
# 복사 후 .env로 저장: cp .env.template .env
# 사용법: source _system/tools/.env (워크스페이스 루트에서 실행)
#
# ⚠️ .env 파일은 절대 git에 커밋하지 마세요.
# ⚠️ 초기 설정은 /platform-setup 스킬로 AI 안내를 받을 수 있습니다.

# ── DISCORD ──────────────────────────────────────────────────────────
# Discord 봇 토큰 (discord.com/developers → Bot → Token)
export DISCORD_BOT_TOKEN=
export DISCORD_TOKEN=$DISCORD_BOT_TOKEN

# Discord 서버 ID (서버 우클릭 → 서버 ID 복사, 개발자 모드 필요)
export DISCORD_GUILD_ID=

# Drop 발행 채널 ID (채널 우클릭 → 채널 ID 복사)
export DISCORD_SHARE_CHANNEL_ID=

# ── DISCORD 운영자 ID ─────────────────────────────────────────────────
# 형식: export DISCORD_USER_{이름}={Discord_사용자_ID}
# /platform-setup 실행 시 자동으로 추가됨
# export DISCORD_USER_홍길동=123456789012345678
# export DISCORD_USER_김철수=987654321098765432

# ── NOTION ────────────────────────────────────────────────────────────
# Notion API 키 (notion.so/my-integrations → Internal Integration Secret)
export NOTION_API_KEY=

# Drops 데이터베이스 ID (DB 페이지 URL에서 추출)
# 형식: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
export NOTION_DROPS_DB_ID=
